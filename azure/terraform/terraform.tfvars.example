# Azure VM Deployment Configuration
# Copy this file to terraform.tfvars and fill in values

# Project
project_name = "mapping-app"
environment  = "prod"
location     = "East US"

# VM
# B2ms recommended for production: 2 vCPU, 8 GB RAM. Bulk-upload processing
# of large vector layers (e.g. multi-million-feature contour datasets via
# OpenFileGDB) needs ~3 GB peak in the backend container; B2s (4 GB total)
# leaves no headroom for that.
vm_size             = "Standard_B2ms"  # 2 vCPU, 8 GB RAM (~$67/month)
# vm_size           = "Standard_B2s"   # 2 vCPU, 4 GB RAM (~$33/month) — light workloads only
admin_username      = "azureuser"
ssh_public_key_path = "~/.ssh/id_rsa.pub"
ssh_allowed_cidr    = "0.0.0.0/0"      # CHANGE: restrict to your IP, e.g. "203.0.113.10/32"

# Domain & SSL
domain_name   = "maps.example.com"     # CHANGE: your domain
certbot_email = "admin@example.com"    # CHANGE: your email for Let's Encrypt

# Database
db_name     = "gis_db"
db_username = "gis_user"

# Data Disk
data_disk_size_gb = 64                 # ~$10/month for Premium SSD

# Application
upload_max_size_mb      = 500
initial_admin_email     = "admin@example.com"   # CHANGE: your admin email
initial_admin_full_name = "Administrator"
gunicorn_workers        = 4

# Off-VM backup replication
# Provisions a private Azure Storage account + container that the VM
# replicates backups to via managed identity. Disable to keep backups
# local-only on the data disk.
enable_backup_blob_storage      = true
backup_storage_replication_type = "LRS"  # use "GRS" to add geo-redundancy (~2x cost)
# backup_storage_account_name   = ""     # leave empty to auto-derive a unique name

# Tags (optional)
tags = {
  managed_by = "terraform"
}

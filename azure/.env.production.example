# Production Environment Variables
# This file is generated by cloud-init with Terraform values.
# Copy and customize if setting up manually without Terraform.

# Database
DB_USER=gis_user
DB_PASSWORD=<generated-by-terraform>
DB_NAME=gis_db

# Backend
SECRET_KEY=<generated-by-terraform>
DOMAIN_NAME=maps.example.com

# Application
UPLOAD_MAX_SIZE_MB=500
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=<generated-by-terraform>
INITIAL_ADMIN_FULL_NAME=Administrator

# Email (optional - if not set, confirmation URLs print to docker logs)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@maps.example.com
SMTP_FROM_NAME=GIS Application

# Off-VM backup replication to Azure Blob Storage (optional but recommended).
# Set AZURE_BACKUP_CONTAINER + one auth method to enable; leave blank to
# keep backups local-only.
#
# Auth option A (recommended on Azure VMs): managed identity. No secrets
# in this file — the VM's system-assigned identity must have
# "Storage Blob Data Contributor" on the storage account.
# AZURE_BACKUP_CONTAINER=backups
# AZURE_STORAGE_ACCOUNT_URL=https://yourstorageaccount.blob.core.windows.net
#
# Auth option B (simplest for non-Azure or local testing): connection
# string with account key. Treat as a secret.
# AZURE_BACKUP_CONTAINER=backups
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# SSL (set by ssl-setup.sh)
# CERTBOT_EMAIL=admin@example.com
